generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── NextAuth adapter models ────────────────────────────────────────────────

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── Application models ─────────────────────────────────────────────────────

model User {
  id           String       @id @default(cuid())
  email        String       @unique
  name         String?
  passwordHash String?
  role         Role         @default(STUDENT)
  // NextAuth adapter fields
  emailVerified DateTime?
  image         String?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  accounts    Account[]
  sessions    Session[]
  submissions Submission[]
}

model Submission {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String
  rawText   String    @db.Text
  fileUrl   String?
  fileType  String?   // pdf | docx | txt
  status    JobStatus @default(PENDING)
  createdAt DateTime  @default(now())

  report Report?
}

model Report {
  id               String        @id @default(cuid())
  submissionId     String        @unique
  submission       Submission    @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  similarityScore  Float         // 0.0 to 1.0
  aiScore          Float?        // 0.0 to 1.0
  aiConfidence     AiConfidence?
  sentenceScores   Json?         // array of {sentence, score, isAi}
  processingTimeMs Int?
  createdAt        DateTime      @default(now())

  matchedSources MatchedSource[]
}

model MatchedSource {
  id           String  @id @default(cuid())
  reportId     String
  report       Report  @relation(fields: [reportId], references: [id], onDelete: Cascade)
  sourceUrl    String
  sourceTitle  String?
  sourceType   String  // web | journal | student_submission
  matchedText  String  @db.Text
  originalText String? @db.Text
  matchScore   Float   // 0.0 to 1.0
  startIndex   Int
  endIndex     Int
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum Role {
  STUDENT
  LECTURER
  ADMIN
}

enum JobStatus {
  PENDING
  PROCESSING
  COMPLETE
  FAILED
}

enum AiConfidence {
  LOW
  MEDIUM
  HIGH
}
